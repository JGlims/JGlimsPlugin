{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "index": 0,
    "cases": [
      {
        "when": "amethyst_armor_boots",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/amethyst_armor_boots"
        }
      },
      {
        "when": "bone_armor_boots",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/bone_armor_boots"
        }
      },
      {
        "when": "sculk_armor_boots",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/sculk_armor_boots"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/iron_boots"
    }
  }
}
{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "index": 0,
    "cases": [
      { "when": "copper_armor_boots", "model": { "type": "minecraft:model", "model": "minecraft:item/copper_armor_boots" } },
      { "when": "chainmail_reinforced_boots", "model": { "type": "minecraft:model", "model": "minecraft:item/chainmail_reinforced_boots" } }
    ],
    "fallback": { "type": "minecraft:model", "model": "minecraft:item/chainmail_boots" }
  }
}
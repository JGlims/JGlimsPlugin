{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "index": 0,
    "cases": [
      {
        "when": "soul_fragment",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/powerups/soul_fragment"
        }
      },
      {
        "when": "infinity_stone_power",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/infinity/infinity_stone_power"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/purple_dye"
    }
  }
}
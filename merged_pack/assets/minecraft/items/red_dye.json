{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "index": 0,
    "cases": [
      {
        "when": "heart_crystal",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/powerups/heart_crystal"
        }
      },
      {
        "when": "infinity_stone_reality",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/infinity/infinity_stone_reality"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/red_dye"
    }
  }
}
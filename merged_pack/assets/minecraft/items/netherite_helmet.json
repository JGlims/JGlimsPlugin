{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "index": 0,
    "cases": [
      { "when": "blood_moon_helmet", "model": { "type": "minecraft:model", "model": "minecraft:item/blood_moon_helmet" } },
      { "when": "natures_embrace_helmet", "model": { "type": "minecraft:model", "model": "minecraft:item/natures_embrace_helmet" } },
      { "when": "frost_warden_helmet", "model": { "type": "minecraft:model", "model": "minecraft:item/frost_warden_helmet" } },
      { "when": "void_walker_helmet", "model": { "type": "minecraft:model", "model": "minecraft:item/void_walker_helmet" } },
      { "when": "dragon_knight_helmet", "model": { "type": "minecraft:model", "model": "minecraft:item/dragon_knight_helmet" } },
      { "when": "abyssal_plate_helmet", "model": { "type": "minecraft:model", "model": "minecraft:item/abyssal_plate_helmet" } }
    ],
    "fallback": { "type": "minecraft:model", "model": "minecraft:item/netherite_helmet" }
  }
}
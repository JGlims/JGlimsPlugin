{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "index": 0,
    "cases": [
      { "when": "copper_armor_leggings", "model": { "type": "minecraft:model", "model": "minecraft:item/copper_armor_leggings" } },
      { "when": "chainmail_reinforced_leggings", "model": { "type": "minecraft:model", "model": "minecraft:item/chainmail_reinforced_leggings" } }
    ],
    "fallback": { "type": "minecraft:model", "model": "minecraft:item/chainmail_leggings" }
  }
}